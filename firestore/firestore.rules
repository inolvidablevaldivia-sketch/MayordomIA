rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Reglas base: solo usuarios autenticados pueden leer/escribir sus datos
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Colecciones específicas
    match /unidades/{unidadId} {
      allow read, write: if request.auth != null;
    }

    match /productos/{productoId} {
      allow read, write: if request.auth != null;
    }

    match /comercios/{comercioId} {
      allow read, write: if request.auth != null;
    }

    match /cuentas/{cuentaId} {
      allow read, write: if request.auth != null;
    }

    match /movimientos/{movimientoId} {
      allow read, write: if request.auth != null;
    }

    match /radar_precios/{radarId} {
      allow read, write: if request.auth != null;
    }

    match /auditoria/{eventoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;  // Solo el sistema escribe
    }

    match /aprendizaje/{correccionId} {
      allow read, write: if request.auth != null;
    }

    match /usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
