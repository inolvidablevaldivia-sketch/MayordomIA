# ============================================================
# MayordomIA - Configuración
# ============================================================
# Copia este archivo como .env y completa los valores

# --- Telegram ---
TELEGRAM_BOT_TOKEN=tu_token_del_bot

# --- Google Gemini ---
GEMINI_API_KEY=tu_api_key_de_gemini
GEMINI_MODEL=gemini-2.0-flash

# --- Firebase ---
FIREBASE_PROJECT_ID=tu_project_id
FIREBASE_PRIVATE_KEY_ID=tu_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\ntu_private_key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=tu_client_email@tu_project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=tu_client_id
FIREBASE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/tu_client_email

# --- App ---
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=DEBUG

# --- OCR ---
TESSERACT_PATH=/usr/bin/tesseract

# --- Dashboard ---
DASHBOARD_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
